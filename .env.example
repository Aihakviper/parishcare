PARISHCARE_APP_NAME=ParishCare MercyFlow API
PARISHCARE_APP_ENV=development
PARISHCARE_DEBUG=true
PARISHCARE_API_V1_PREFIX=/api/v1

POSTGRES_DB=parishcare
POSTGRES_USER=parishcare
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
PARISHCARE_DATABASE_URL=postgresql+asyncpg://parishcare:change-me@db:5432/parishcare

PARISHCARE_JWT_SECRET_KEY=replace-with-a-long-random-secret
PARISHCARE_JWT_ALGORITHM=HS256
PARISHCARE_JWT_ISSUER=parishcare-mercyflow
PARISHCARE_JWT_AUDIENCE=parishcare-api
PARISHCARE_ACCESS_TOKEN_EXPIRE_MINUTES=15
PARISHCARE_REFRESH_TOKEN_EXPIRE_DAYS=7

# Generate each value independently:
# python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
PARISHCARE_PII_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
PARISHCARE_PII_LOOKUP_KEY=AQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQE=
